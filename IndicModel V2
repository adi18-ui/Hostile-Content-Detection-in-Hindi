      "source": [
        "def clean_text(text):\n",
        "    # 1. Remove URLs\n",
        "    text = re.sub(r'https?://\\S+|www\\.\\S+', '', text)\n",
        "\n",
        "    # 2. Remove hashtags and mentions (no space)\n",
        "    text = re.sub(r'[@#]\\S+', '', text)\n",
        "\n",
        "    # 3. Remove Emojis\n",
        "    # text = emoji.replace_emoji(text, replace='')\n",
        "\n",
        "    text = emoji.demojize(text, language='en')\n",
        "    text = text.replace(\":\", \" \").replace(\"_\", \" \")\n",
        "\n",
        "    # # 4. Remove numbers\n",
        "    # text = re.sub(r'\\d+', '', text)\n",
        "\n",
        "    # # 5. Remove all symbols except Hindi + space\n",
        "    # text = re.sub(r'[^\\u0900-\\u097F\\s]', '', text)\n",
        "\n",
        "    # 6. Remove extra spaces\n",
        "    text = re.sub(r'\\s+', ' ', text).strip()\n",
        "\n",
        "    return text\n",
        "\n",
        "\n",
        "\n",
        "# Apply the cleaning pipeline to all dataframes\n",
        "for df in [df_train, df_valid, df_test]:\n",
        "    df['cleaned_Post'] = df['Post'].apply(clean_text)\n",
        "    # Drop the original 'Post' column\n",
        "    df.drop(columns=['Post'], inplace=True)\n",
