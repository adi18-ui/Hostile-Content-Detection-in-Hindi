        "hostile_keywords = {\"hate\", \"offensive\", \"fake\", \"defamation\"}\n",
        "\n",
        "def label_to_binary(label_str):\n",
        "    # Handle NaN values explicitly, assuming they are non-hostile\n",
        "    if pd.isna(label_str):\n",
        "        return 0\n",
        "\n",
        "    # Ensure the input is treated as a string before splitting\n",
        "    labels = [x.strip().lower() for x in str(label_str).split(\",\")]\n",
        "\n",
        "    if \"non-hostile\" in labels:\n",
        "        return 0\n",
        "\n",
        "    # if ANY hostile tag is present\n",
        "    for tag in labels:\n",
        "        if tag in hostile_keywords:\n",
        "            return 1\n",
        "\n",
        "    return 0\n",
        "\n",
        "# Apply to training and validation sets\n",
        "df_train[\"target\"] = df_train[\"Labels Set\"].apply(label_to_binary)\n",
        "df_valid[\"target\"] = df_valid[\"Labels Set\"].apply(label_to_binary)\n",
        "df_test[\"target\"] = df_test[\"Labels Set\"].apply(label_to_binary)\n",
        "\n",
