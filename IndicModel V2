        "import torch\n",
        "import torch.nn as nn\n",
        "from transformers import AutoModel\n",
        "import lightning as L\n",
        "from torchmetrics.classification import F1Score, Accuracy # Import Accuracy\n",
        "\n",
        "class Indic_bert_CNN(L.LightningModule):\n",
        "    def __init__(self, lr=2e-5, dropout_rate=0.2, label_smoothing_factor=0.1):\n",
        "        super().__init__()\n",
        "        self.lr = lr\n",
        "        self.label_smoothing_factor = label_smoothing_factor\n",
        "\n",
        "\n",
        "        self.bert = AutoModel.from_pretrained(\"ai4bharat/IndicBERTv2-MLM-only\")\n",
        "\n",
        "        # CNN layers (input is token embeddings of size 768)\n",
        "        self.cnn = nn.Sequential(\n",
        "            nn.Conv1d(in_channels=768, out_channels=384, kernel_size=3, padding=1),\n",
        "            # nn.Conv1d(in_channels=256, out_channels=384, kernel_size=3, padding=1),\n",
        "            nn.BatchNorm1d(384),\n",
        "            nn.ReLU(),\n",
        "            # nn.Dropout(0.2),\n",
        "            nn.Conv1d(384, 256, kernel_size=3, padding=1),\n",
        "            nn.BatchNorm1d(256),\n",
        "            nn.ReLU(),\n",
        "            # nn.Dropout(0.2),\n",
        "            nn.Conv1d(256, 128, kernel_size=3, padding=1),\n",
        "            nn.ReLU(),\n",
        "            # nn.AdaptiveAvgPool1d(1)  # → shape becomes (B, 128, 1)\n",
        "        )\n",
        "\n",
        "        self.transformer = TransformerWithPosEncoding(\n",
        "            model_dim=128,\n",
        "            nhead=8,\n",
        "            num_layers=4,\n",
        "            dropout=dropout_rate\n",
        "        )\n",
        "\n",
        "        # Final classifier\n",
        "        self.pool = nn.AdaptiveAvgPool1d(1)\n",
        "\n",
        "        # projection head\n",
        "        self.projection = nn.Sequential(\n",
        "            nn.Linear(128, 64),\n",
        "            nn.ReLU(),\n",
        "            nn.Linear(64, 32)\n",
        "        )\n",
        "\n",
        "        # classifier\n",
        "        self.fc = nn.Linear(32, 1)\n",
        "        self.sigmoid = nn.Sigmoid()\n",
        "        self.loss_fn = nn.BCELoss()\n",
        "\n",
        "        # F1 and Accuracy trackers\n",
        "        self.train_f1 = F1Score(task='binary', average='macro')\n",
        "        self.val_f1 = F1Score(task='binary', average='macro')\n",
        "        self.test_f1 = F1Score(task='binary', average='macro')\n",
        "        self.test_accuracy = Accuracy(task='binary')\n",
        "        # For confusion matrix\n",
        "        self.test_preds = []\n",
        "        self.test_labels = []\n",
        "\n",
        "        self.training_step_losses = []\n",
        "\n",
        "    def forward(self, input_ids, attention_mask):\n",
        "\n",
        "        out = self.bert(input_ids=input_ids, attention_mask=attention_mask, return_dict=True)\n",
        "        sequence_output = out.last_hidden_state  # (B, seq, 768)\n",
        "\n",
        "        # Convert to CNN format: (B, channels=768, seq)\n",
        "        x = sequence_output.permute(0, 2, 1)\n",
        "\n",
        "        # CNN feature extraction\n",
        "        x = self.cnn(x)          # (B, 128, 1)\n",
        "\n",
        "        # Transformer encoder\n",
        "        x = x.transpose(1, 2)    # (B, 1, 128)\n",
        "        x = self.transformer(x)\n",
        "        x = x.transpose(1, 2)    # (B, 128, 1)\n",
        "\n",
        "        x = self.pool(x)\n",
        "        x = x.squeeze(2)        # (B,128)\n",
        "\n",
        "        embedding = self.projection(x)   # (B,32)\n",
        "\n",
        "        logits = self.fc(embedding)\n",
        "        probs = self.sigmoid(logits)\n",
        "\n",
        "        return probs.squeeze(1)\n",
        "\n",
        "    def get_embeddings(self, input_ids, attention_mask):\n",
        "\n",
        "        self.eval()\n",
        "\n",
        "        with torch.no_grad():\n",
        "\n",
        "            out = self.bert(input_ids=input_ids, attention_mask=attention_mask)\n",
        "            x = out.last_hidden_state\n",
        "\n",
        "            x = x.permute(0,2,1)\n",
        "            x = self.cnn(x)\n",
        "\n",
        "            x = x.transpose(1,2)\n",
        "            x = self.transformer(x)\n",
        "            x = x.transpose(1,2)\n",
        "\n",
        "            x = self.pool(x).squeeze(2)\n",
        "\n",
        "            embedding = self.projection(x)\n",
        "\n",
        "        return embedding\n",
        "\n",
        "    def training_step(self, batch, batch_idx):\n",
        "        preds = self(batch[\"input_ids\"], batch[\"attention_mask\"])\n",
        "\n",
        "        # Apply label smoothing\n",
        "        smoothed_labels = batch[\"label\"] * (1 - self.label_smoothing_factor) + 0.5 * self.label_smoothing_factor\n",
        "        loss = self.loss_fn(preds, smoothed_labels)\n",
        "\n",
        "        self.log(\"train_loss_step\", loss, prog_bar=True)\n",
        "        self.training_step_losses.append(loss.item())\n",
        "\n",
        "        # Calculate and log F1 score using original hard labels for metrics\n",
        "        self.train_f1.update(preds, batch[\"label\"].int())\n",
        "        self.log(\"train_f1_step\", self.train_f1, prog_bar=True)\n",
        "        return loss\n",
        "\n",
        "    def on_train_epoch_end(self):\n",
        "        # Log epoch-level F1 score\n",
        "        self.log(\"train_f1_epoch\", self.train_f1.compute(), prog_bar=True)\n",
        "        self.train_f1.reset()\n",
        "\n",
        "        # Calculate and log epoch-level average training loss\n",
        "        if self.training_step_losses:\n",
        "            avg_train_loss = torch.tensor(self.training_step_losses).mean()\n",
        "            self.log(\"train_loss_epoch\", avg_train_loss, prog_bar=True)\n",
        "            self.training_step_losses.clear()\n",
        "\n",
        "\n",
        "    def validation_step(self, batch, batch_idx):\n",
        "        preds = self(batch[\"input_ids\"], batch[\"attention_mask\"])\n",
        "\n",
        "        # Apply label smoothing\n",
        "        smoothed_labels = batch[\"label\"] * (1 - self.label_smoothing_factor) + 0.5 * self.label_smoothing_factor\n",
        "        loss = self.loss_fn(preds, smoothed_labels)\n",
        "\n",
        "        self.log(\"val_loss\", loss, prog_bar=True)\n",
        "\n",
        "\n",
        "        self.val_f1.update(preds, batch[\"label\"].int())\n",
        "        self.log(\"val_f1_step\", self.val_f1, prog_bar=True)\n",
        "\n",
        "    def on_validation_epoch_end(self):\n",
        "\n",
        "        self.log(\"val_f1_epoch\", self.val_f1.compute(), prog_bar=True)\n",
        "        self.val_f1.reset()\n",
        "\n",
        "    def on_test_epoch_start(self):\n",
        "        self.test_preds = []\n",
        "        self.test_labels = []\n",
        "\n",
        "    def test_step(self, batch, batch_idx):\n",
        "        preds = self(batch[\"input_ids\"], batch[\"attention_mask\"])\n",
        "        loss = self.loss_fn(preds, batch[\"label\"])\n",
        "        self.log(\"test_loss\", loss, prog_bar=True)\n",
        "\n",
        "\n",
        "        self.test_f1.update(preds, batch[\"label\"].int())\n",
        "        self.test_accuracy.update(preds, batch[\"label\"].int())\n",
        "        self.log(\"test_f1_step\", self.test_f1, prog_bar=True)\n",
        "        self.log(\"test_accuracy_step\", self.test_accuracy, prog_bar=True)\n",
        "\n",
        "        # Store predictions and labels for confusion matrix\n",
        "        self.test_preds.append(preds.cpu())\n",
        "        self.test_labels.append(batch[\"label\"].cpu())\n",
        "        return loss\n",
        "\n",
        "    def on_test_epoch_end(self):\n",
        "        # Log epoch-level F1 score and Accuracy\n",
        "        self.log(\"test_f1_epoch\", self.test_f1.compute(), prog_bar=True)\n",
        "        self.log(\"test_accuracy_epoch\", self.test_accuracy.compute(), prog_bar=True)\n",
        "        self.test_f1.reset()\n",
        "        self.test_accuracy.reset()\n",
        "\n",
        "        # Combine all predictions and labels\n",
        "        self.all_test_preds = torch.cat(self.test_preds)\n",
        "        self.all_test_labels = torch.cat(self.test_labels)\n",
        "\n",
        "    def configure_optimizers(self):\n",
        "        return torch.optim.AdamW(self.parameters(), lr=self.lr)"
